# ---- OS / editors ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml
*.swp

# ---- Frontend Vite/React source (bundle output is committed) ----
# frontend/index.html is the bundled artifact (committed). The Vite source
# project under frontend/app/ generates it via the web-artifacts-builder skill;
# its node_modules + build caches do not belong in git.
frontend/app/node_modules/
frontend/app/dist/
frontend/app/.parcel-cache/
frontend/app/bundle.html

# ---- Claude Code local state ----
# The whole .claude/ directory is per-user (settings, launch config,
# scheduled-task lockfiles, session logs, slash commands).
.claude/

# ---- Java / Maven ----
core-api/target/
core-api/.mvn/wrapper/maven-wrapper.jar
core-api/build/
core-api/out/
core-api/**/*.class
core-api/logs/
core-api/HELP.md

# ---- Python ----
ai-worker/.venv/
ai-worker/venv/
ai-worker/__pycache__/
ai-worker/**/__pycache__/
ai-worker/**/*.pyc
ai-worker/.pytest_cache/
ai-worker/.mypy_cache/
ai-worker/*.egg-info/

# ---- Eval harness generated artifacts ----
# Reports change every run and should not be committed. Sample OCR
# fixture images are synthesized by scripts/make_ocr_sample_fixtures.py
# and drift across fonts, so they are regenerated on demand. Phase-0
# baseline reports are the one exception — they anchor the README
# benchmark table and later phases diff against them.
ai-worker/eval/reports/*
!ai-worker/eval/reports/baseline-phase0.json
!ai-worker/eval/reports/baseline-phase0-anime.json
# Phase 8 agent-loop decision: the markdown + backing JSON are the
# record of the measured A/B, not a run-to-run report.
!ai-worker/eval/reports/agent-loop-decision.md
!ai-worker/eval/reports/agent-loop-decision.json
ai-worker/eval/datasets/samples/

# ---- Optuna tuning artifacts ----
# Keep summary.md + config.yaml (deterministic replay), drop the
# binary SQLite study and per-run plots. See docs/tuning.md.
ai-worker/eval/experiments/studies/**/study.db
ai-worker/eval/experiments/studies/**/study.db-journal
ai-worker/eval/experiments/studies/**/plots/

# ---- Demo script generated assets ----
scripts/assets/

# ---- Local runtime state ----
data/
!data/.gitkeep
local-storage/
!local-storage/.gitkeep
*.log

# ---- Docker volumes (if bound locally) ----
infra/postgres/data/
infra/redis/data/
infra/minio/data/

# ---- Phase 9 dataset artifacts (local-only) ----
# The full 1,764-title namu-wiki sample lives outside the repo; if a
# contributor stages it locally, keep it out of git. We commit only the
# 300-title reservoir sample at fixtures/anime_corpus_kr.jsonl (~17 MB).
ai-worker/fixtures/corpus_anime_full/
# sample_check.py HTML reports + reviewer annotation JSONs are local.
review/

# ---- Retrieval-eval corpora (local-only, large) ----
# Full source corpora live under ai-worker/eval/corpora/<name>/corpus.jsonl
# and are too large to commit (e.g. namu_anime_v3 is ~261 MB). The
# accompanying README.md is committed so contributors know how to
# re-stage the file from its source path.
ai-worker/eval/corpora/**/*.jsonl
!ai-worker/eval/corpora/**/README.md
# Generated silver query sets are reproducible via
# eval.harness.generate_eval_queries; keep them local. Hand-authored
# smoke and gold sets ARE committed (small + verified).
ai-worker/eval/eval_queries/*_silver_*.jsonl
ai-worker/eval/eval_queries/*_synthetic_*.jsonl
ai-worker/eval/eval_queries/_generation_log_*.jsonl

# ---- RAG build artifacts (local-only) ----
# FAISS index + build manifest are rebuilt from fixtures via
# scripts/build_rag_index.py; keep them out of git.
rag-data/*.index
rag-data/build.json

# ---- Optuna round-refinement run artifacts ----
# study_bundle.json + llm_input.md emitted by the skill's round_runner
# are per-run artifacts; only the .gitkeep is tracked so the directory
# survives a fresh clone.
ai-worker/eval/experiments/run_output/
!ai-worker/eval/experiments/run_output/.gitkeep

# ---- Working notes / decision logs / personal context ----
# Trade-off records, session work logs, and decision/process docs are
# local-only by default. They typically capture per-author context,
# private discussion, or in-progress reasoning that does not belong on
# the main branch. Promote a doc out of these patterns only when it is
# explicitly meant as canonical project documentation.
**/*-tradeoffs.md
**/*-tradeoff.md
**/*-trade-offs.md
**/*-trade-off.md
**/*-session-log.md
**/*-session-log-*.md
**/*-worklog.md
**/*-worklog-*.md
**/*-personal.md
**/*-private.md
**/notes/
**/_scratch/
**/_local/
**/_drafts/
# Phase 0 baseline tradeoffs / decisions doc — local-only by policy.
ai-worker/eval/reports/phase0-baseline-tradeoffs.md

