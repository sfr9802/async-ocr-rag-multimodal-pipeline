# ai-worker local development overrides.
# Copy to `.env` in this directory and edit as needed. Variables here are
# loaded by pydantic-settings at worker startup.

AIPIPELINE_WORKER_WORKER_ID=worker-local-1
AIPIPELINE_WORKER_CORE_API_BASE_URL=http://localhost:8080
AIPIPELINE_WORKER_REDIS_URL=redis://localhost:6379/0
AIPIPELINE_WORKER_QUEUE_PENDING_KEY=aipipeline:jobs:pending

# Shared artifact root. Must match core-api's aipipeline.storage.local.root-dir.
# When commented out, the worker falls back to `../local-storage` relative to
# the working directory (i.e. ai-worker/), which puts the folder at the repo root.
# AIPIPELINE_WORKER_LOCAL_STORAGE_ROOT=D:/async-ocr-rag-multimodal-pipeline/local-storage

AIPIPELINE_WORKER_MOCK_PROCESSING_DELAY_MS=200

# ---------------------------------------------------------------------------
# RAG capability (phase 2).
# ---------------------------------------------------------------------------
# Default embedding model is BAAI/bge-m3: multilingual, 1024-dim, ~2.3 GB
# download on first use. bge-m3 is trained without query/passage prefixes
# so both prefix knobs below are empty strings by default. The worker and
# the indexing CLI must be run with the SAME model name — mismatch causes a
# hard failure at RAG capability registration (MOCK still registers).
#
# AIPIPELINE_WORKER_RAG_ENABLED=true
# AIPIPELINE_WORKER_RAG_EMBEDDING_MODEL=BAAI/bge-m3
# AIPIPELINE_WORKER_RAG_EMBEDDING_PREFIX_QUERY=
# AIPIPELINE_WORKER_RAG_EMBEDDING_PREFIX_PASSAGE=
# AIPIPELINE_WORKER_RAG_INDEX_DIR=../rag-data
# AIPIPELINE_WORKER_RAG_TOP_K=5
#
# Alternative: smaller English-only model (no download cost on tight disks).
# Remember to rebuild the index AND restart the worker whenever this value
# changes — see docs/local-run.md "Migrating the embedding model".
# AIPIPELINE_WORKER_RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
#
# Alternative: E5 family needs explicit query/passage prefixes. The trailing
# space inside the quotes is load-bearing — E5 models expect "query: ..." and
# "passage: ..." exactly.
# AIPIPELINE_WORKER_RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# AIPIPELINE_WORKER_RAG_EMBEDDING_PREFIX_QUERY="query: "
# AIPIPELINE_WORKER_RAG_EMBEDDING_PREFIX_PASSAGE="passage: "

# ---------------------------------------------------------------------------
# OCR capability (phase 2).
# ---------------------------------------------------------------------------
# Tesseract (via pytesseract) + PyMuPDF handle images and PDFs. See
# docs/local-run.md "Phase 2: OCR capability" for install steps. If the
# tesseract binary or a requested language pack is missing, OCR fails
# to register at worker startup — MOCK and RAG still register.
#
# AIPIPELINE_WORKER_OCR_ENABLED=true
# AIPIPELINE_WORKER_OCR_LANGUAGES=eng
# AIPIPELINE_WORKER_OCR_PDF_DPI=200
# AIPIPELINE_WORKER_OCR_MIN_CONFIDENCE_WARN=40.0
# AIPIPELINE_WORKER_OCR_MAX_PAGES=100
#
# Windows: set this if tesseract.exe is not on PATH.
# AIPIPELINE_WORKER_OCR_TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
#
# Korean + English example (requires tesseract-ocr-kor installed):
# AIPIPELINE_WORKER_OCR_LANGUAGES=eng+kor
