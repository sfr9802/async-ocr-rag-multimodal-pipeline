# Enterprise Korean AUTO-routing eval set (seed, n=15).
# Each row exercises the AgentRouterProvider: given (text, has_file,
# file_mime), the router must pick one of:
#   rag           — text-only question about the corpus
#   ocr           — image/pdf + no meaningful question
#   multimodal    — image/pdf + a question about the image
#   direct_answer — conversational / no-corpus answer
#   clarify       — empty or too short to route
#
# Full 80-row set is generated by scripts.dataset.generate_routing_cases
# once the 125-doc corpus + enterprise multimodal images are in place.
{"query": "재택근무 신청 기한이 어떻게 되나요?", "has_file": false, "file_mime": null, "expected_action": "rag", "notes": "corpus question -> rag"}
{"query": "법인카드 증빙 등록 기한은 며칠인가요?", "has_file": false, "file_mime": null, "expected_action": "rag", "notes": "corpus question -> rag"}
{"query": "Kubernetes 클러스터의 1차 알림 채널은?", "has_file": false, "file_mime": null, "expected_action": "rag", "notes": "corpus question -> rag"}
{"query": "NDA 체결 시 법무팀 검토 기한은?", "has_file": false, "file_mime": null, "expected_action": "rag", "notes": "corpus question -> rag"}
{"query": "이 이미지에 어떤 내용이 있나요?", "has_file": true, "file_mime": "image/png", "expected_action": "multimodal", "notes": "question about image -> multimodal"}
{"query": "이 PDF에서 p99 응답 지연 수치를 찾아주세요", "has_file": true, "file_mime": "application/pdf", "expected_action": "multimodal", "notes": "question about PDF -> multimodal"}
{"query": "이 포스터의 제목이 뭐야?", "has_file": true, "file_mime": "image/jpeg", "expected_action": "multimodal", "notes": "question about image -> multimodal"}
{"query": "", "has_file": true, "file_mime": "image/png", "expected_action": "ocr", "notes": "file only, no question -> ocr"}
{"query": "", "has_file": true, "file_mime": "application/pdf", "expected_action": "ocr", "notes": "PDF only, no question -> ocr"}
{"query": "텍스트만 추출해줘", "has_file": true, "file_mime": "image/png", "expected_action": "ocr", "notes": "OCR-style request + image -> ocr"}
{"query": "안녕하세요", "has_file": false, "file_mime": null, "expected_action": "direct_answer", "notes": "greeting -> direct_answer"}
{"query": "감사합니다", "has_file": false, "file_mime": null, "expected_action": "direct_answer", "notes": "closing -> direct_answer"}
{"query": "?", "has_file": false, "file_mime": null, "expected_action": "clarify", "notes": "too short to route -> clarify"}
{"query": "", "has_file": false, "file_mime": null, "expected_action": "clarify", "notes": "empty -> clarify"}
{"query": "ok", "has_file": false, "file_mime": null, "expected_action": "clarify", "notes": "2-char -> clarify"}
