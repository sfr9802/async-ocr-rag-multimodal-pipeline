# Multimodal eval dataset — tests OCR-only, visual-only, and OCR+visual rows.
# Images are generated by scripts/make_multimodal_sample_fixtures.py into
# samples/multimodal/. Regenerate with:
#   python -m scripts.make_multimodal_sample_fixtures
#
# Row types:
#   1. OCR-only (requires_ocr=true): answer can be found by reading text
#   2. Visual-only: answer requires understanding shapes/colors/layout
#   3. OCR+visual: answer requires both text extraction and visual context
#
# Schema: image, question, expected_answer, expected_keywords,
#         expected_labels, requires_ocr, language, notes

# --- OCR-only rows ---
{"image": "samples/multimodal/invoice_text.png", "question": "What is the total amount on this invoice?", "expected_answer": "$257.50", "expected_keywords": ["257.50", "invoice"], "expected_labels": [], "requires_ocr": true, "language": "eng", "notes": "OCR-only EN: number extraction from invoice text"}
{"image": "samples/multimodal/kr_notice_text.png", "question": "서버 점검은 몇 시에 시작하나요?", "expected_answer": "오전 2시", "expected_keywords": ["2시", "점검"], "expected_labels": [], "requires_ocr": true, "language": "kor", "notes": "OCR-only KR: time extraction from notice"}
{"image": "samples/multimodal/kr_security_text.png", "question": "비밀번호 최소 길이는?", "expected_answer": "12자", "expected_keywords": ["12자", "비밀번호"], "expected_labels": [], "requires_ocr": true, "language": "kor", "notes": "OCR-only KR: security policy question"}

# --- Visual-only rows ---
{"image": "samples/multimodal/shapes_visual.png", "question": "What geometric shapes are visible in the image?", "expected_answer": null, "expected_keywords": ["circle", "rectangle", "triangle"], "expected_labels": ["red", "blue", "green"], "requires_ocr": false, "language": "eng", "notes": "Visual-only: shape and color identification"}
{"image": "samples/multimodal/bar_chart.png", "question": "Which bar in the chart is the tallest?", "expected_answer": null, "expected_keywords": ["tall", "bar"], "expected_labels": ["blue"], "requires_ocr": false, "language": "eng", "notes": "Visual-only: bar chart height comparison"}

# --- OCR + Visual rows ---
{"image": "samples/multimodal/labeled_diagram.png", "question": "What components are shown in the system architecture diagram and how are they connected?", "expected_answer": null, "expected_keywords": ["Frontend", "Backend", "Database"], "expected_labels": ["Frontend", "Backend", "Database"], "requires_ocr": true, "language": "eng", "notes": "OCR+visual EN: labeled architecture diagram requires reading labels and understanding arrows"}
{"image": "samples/multimodal/kr_labeled_diagram.png", "question": "이 시스템 구성도에서 어떤 구성 요소가 있나요?", "expected_answer": null, "expected_keywords": ["웹 서버", "API 서버", "데이터베이스"], "expected_labels": ["웹 서버", "API 서버", "데이터베이스"], "requires_ocr": true, "language": "kor", "notes": "OCR+visual KR: Korean labeled system diagram"}
