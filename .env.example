# =============================================================================
# Environment variables for local development.
# Copy this file to `.env` (at the repo root) and source it before running
# core-api / ai-worker if you need to override the defaults.
#
# The defaults below match MODE A: reusing an existing postgres container
# on :5432 with a dedicated `aipipeline` database + user.
# =============================================================================

# ---------------------------------------------------------------------------
# Shared: artifact storage root
# ---------------------------------------------------------------------------
# Absolute path to the local-storage directory that BOTH core-api and the
# worker will read/write. If unset, both sides fall back to `../local-storage`
# resolved relative to their working directory, which normally puts the
# folder at the repo root.
# AIPIPELINE_STORAGE_LOCAL_ROOT_DIR=D:/async-ocr-rag-multimodal-pipeline/local-storage

# ---------------------------------------------------------------------------
# core-api (Spring Boot) — Mode A defaults
# ---------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aipipeline
SPRING_DATASOURCE_USERNAME=aipipeline
SPRING_DATASOURCE_PASSWORD=aipipeline_pw
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SERVER_PORT=8080
AIPIPELINE_QUEUE_PENDING_KEY=aipipeline:jobs:pending
AIPIPELINE_WORKER_CALLBACK_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# core-api — Mode B override (bundled postgres from docker-compose.yml on :5433)
# ---------------------------------------------------------------------------
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/aipipeline
# SPRING_DATASOURCE_USERNAME=aipipeline
# SPRING_DATASOURCE_PASSWORD=aipipeline_pw

# ---------------------------------------------------------------------------
# ai-worker (Python)
# ---------------------------------------------------------------------------
AIPIPELINE_WORKER_WORKER_ID=worker-local-1
AIPIPELINE_WORKER_CORE_API_BASE_URL=http://localhost:8080
AIPIPELINE_WORKER_REDIS_URL=redis://localhost:6379/0
AIPIPELINE_WORKER_QUEUE_PENDING_KEY=aipipeline:jobs:pending
# AIPIPELINE_WORKER_LOCAL_STORAGE_ROOT=D:/async-ocr-rag-multimodal-pipeline/local-storage
AIPIPELINE_WORKER_MOCK_PROCESSING_DELAY_MS=200
