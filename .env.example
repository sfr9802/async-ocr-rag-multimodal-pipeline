# =============================================================================
# Environment variables for local development.
# Copy this file to `.env` (at the repo root) and source it before running
# core-api / ai-worker if you need to override the defaults.
#
# The defaults below match MODE A: reusing an existing postgres container
# on :5432 with a dedicated `aipipeline` database + user.
# =============================================================================

# ---------------------------------------------------------------------------
# Shared: artifact storage root
# ---------------------------------------------------------------------------
# Absolute path to the local-storage directory that BOTH core-api and the
# worker will read/write. If unset, both sides fall back to `../local-storage`
# resolved relative to their working directory, which normally puts the
# folder at the repo root.
# AIPIPELINE_STORAGE_LOCAL_ROOT_DIR=D:/async-ocr-rag-multimodal-pipeline/local-storage

# ---------------------------------------------------------------------------
# core-api (Spring Boot) — Mode A defaults
# ---------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aipipeline
SPRING_DATASOURCE_USERNAME=aipipeline
SPRING_DATASOURCE_PASSWORD=aipipeline_pw
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SERVER_PORT=8080
AIPIPELINE_QUEUE_PENDING_KEY=aipipeline:jobs:pending
AIPIPELINE_WORKER_CALLBACK_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# core-api — Mode B override (bundled postgres from docker-compose.yml on :5433)
# ---------------------------------------------------------------------------
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/aipipeline
# SPRING_DATASOURCE_USERNAME=aipipeline
# SPRING_DATASOURCE_PASSWORD=aipipeline_pw

# ---------------------------------------------------------------------------
# Shared secret for /api/internal/* authentication
# ---------------------------------------------------------------------------
# Both core-api and ai-worker must share the same secret VALUE, even though
# the env var names differ (AIPIPELINE_INTERNAL_SECRET for core-api,
# AIPIPELINE_WORKER_INTERNAL_SECRET for the worker). When unset, core-api
# runs in dev pass-through mode (WARN logged once at startup).
# AIPIPELINE_INTERNAL_SECRET=change-me-in-production
# AIPIPELINE_WORKER_INTERNAL_SECRET=change-me-in-production

# ---------------------------------------------------------------------------
# ai-worker (Python)
# ---------------------------------------------------------------------------
AIPIPELINE_WORKER_WORKER_ID=worker-local-1
AIPIPELINE_WORKER_CORE_API_BASE_URL=http://localhost:8080
AIPIPELINE_WORKER_REDIS_URL=redis://localhost:6379/0
AIPIPELINE_WORKER_QUEUE_PENDING_KEY=aipipeline:jobs:pending
# AIPIPELINE_WORKER_LOCAL_STORAGE_ROOT=D:/async-ocr-rag-multimodal-pipeline/local-storage
AIPIPELINE_WORKER_MOCK_PROCESSING_DELAY_MS=200

# --- S3 / MinIO storage (when core-api uses backend=s3) ---
# AIPIPELINE_STORAGE_BACKEND=s3
# AIPIPELINE_STORAGE_S3_ENDPOINT=http://localhost:9000
# AIPIPELINE_STORAGE_S3_REGION=us-east-1
# AIPIPELINE_STORAGE_S3_BUCKET=aipipeline-artifacts
# AIPIPELINE_STORAGE_S3_ACCESS_KEY=aipipeline
# AIPIPELINE_STORAGE_S3_SECRET_KEY=aipipeline_secret
# AIPIPELINE_WORKER_S3_ENDPOINT=http://localhost:9000
# AIPIPELINE_WORKER_S3_ACCESS_KEY=aipipeline
# AIPIPELINE_WORKER_S3_SECRET_KEY=aipipeline_secret

# --- Claude Vision + Generation providers (requires Anthropic API key) ---
# AIPIPELINE_WORKER_ANTHROPIC_API_KEY=sk-ant-...
# AIPIPELINE_WORKER_MULTIMODAL_VISION_PROVIDER=claude
# AIPIPELINE_WORKER_MULTIMODAL_CLAUDE_VISION_MODEL=claude-sonnet-4-6
# AIPIPELINE_WORKER_MULTIMODAL_CLAUDE_TIMEOUT_SECONDS=30.0
# AIPIPELINE_WORKER_RAG_GENERATOR=claude
# AIPIPELINE_WORKER_RAG_CLAUDE_GENERATION_MODEL=claude-sonnet-4-6
# AIPIPELINE_WORKER_RAG_GENERATOR_FALLBACK_ON_ERROR=true
# AIPIPELINE_WORKER_RAG_CLAUDE_TIMEOUT_SECONDS=60.0

# --- Cross-modal retrieval (opt-in, requires CLIP image index) ---
# AIPIPELINE_WORKER_CROSS_MODAL_ENABLED=false
# AIPIPELINE_WORKER_CROSS_MODAL_CLIP_MODEL=sentence-transformers/clip-ViT-B-32
# AIPIPELINE_WORKER_CROSS_MODAL_RRF_K=60
